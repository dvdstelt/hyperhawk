{
    "name":  "hyperhawk",
    "version":  "1.3.1",
    "description":  "GitHub Action that scans markdown files for broken links",
    "main":  "dist/index.js",
    "scripts":  {
                    "build":  "ncc build src/index.ts -o dist --minify --source-map --license licenses.txt",
                    "build:dev":  "ncc build src/index.ts -o dist",
                    "typecheck":  "tsc --noEmit",
                    "lint":  "tsc --noEmit"
                },
    "dependencies":  {
                         "@actions/core":  "^1.10.1",
                         "@actions/github":  "^6.0.0",
                         "@actions/glob":  "^0.4.0"
                     },
    "devDependencies":  {
                            "@types/node":  "^20.0.0",
                            "@vercel/ncc":  "^0.38.0",
                            "typescript":  "^5.4.0"
                        },
    "keywords":  [
                     "github-action",
                     "link-checker",
                     "markdown"
                 ],
    "license":  "MIT"
}
